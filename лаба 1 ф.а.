def subtract_binary_distribution_simple(a, b):
  if a == b:
    return 0

  if a > b:
    start, target = b, a
    positive = True
  else:
    start, target = a, b
    positive = False
    
  result = 0
  step = 1
  while result + step + start < target:
    result += step
    step *= 2
  while result + start < target:
    result += 1
    return result if positive else -result
print(subtract_binary_distribution_simple(10, 7))  # 3

